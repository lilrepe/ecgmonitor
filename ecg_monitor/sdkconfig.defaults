# FreeRTOS: tăng tick rate lên 1000Hz để vTaskDelay(1) = 1ms (thay vì 10ms mặc định)
CONFIG_FREERTOS_HZ=1000

# Cho phép task chạy trên core cụ thể
CONFIG_FREERTOS_UNICORE=n

# Stack overflow check (development)
CONFIG_FREERTOS_WATCHPOINT_END_OF_STACK=y

# Log level
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# ADC
CONFIG_ADC_SUPPRESS_DEPRECATE_WARN=y

# WiFi
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=10
CONFIG_ESP_WIFI_DYNAMIC_TX_BUFFER_NUM=32

# WebSocket / HTTP server
CONFIG_HTTPD_MAX_OPEN_SOCKETS=7
CONFIG_HTTPD_WS_SUPPORT=y

# Tăng stack cho main task (dùng khi init)
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_ECG_UNIT_TEST=y

# Serial Debug Mode (Yêu cầu 1) — chỉ ADC + UART print, bỏ qua inference/display/network
# Tắt dòng này khi chuyển sang Yêu cầu 2 (OLED)
CONFIG_ECG_SERIAL_DEBUG=y
